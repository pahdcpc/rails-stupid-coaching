<div class="container mt-5">
  <h1>Stupid Coaching</h1>

  <div class="card mb-3">
    <div class="card-body">
      <p><strong>You:</strong> <%= @question %></p>
    </div>
  </div>

  <div class="card bg-light">
    <div class="card-body">
      <p><strong>Coach:</strong> <%= @answer %></p>
    </div>
  </div>

  <%= link_to "Ask a new question", ask_path, class: "btn btn-secondary mt-3" %>
</div>
